{% extends 'base_admin.html.twig' %}

{% block title %}Membre
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Membre</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ membre.id }}</td>
				</tr>
				<tr>
					<th>Capital</th>
					<td>{{ membre photo }}</td>
				</tr>
				<tr>
					<th>Nom</th>
					<td>{{ membre.nom }}</td>
				</tr>
				<tr>
					<th>Adresse</th>
					<td>{{ membre.prenom }}</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('membre_index') }}" class="btn btn-secondary">Liste de sieges</a>

		<a href="{{ path('membre_edition', {'id': membre.id}) }}" class="btn btn-secondary">Modifier</a>

		{{ include('membre/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
