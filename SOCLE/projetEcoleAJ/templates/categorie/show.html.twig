{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Matiere</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ categorie.id }}</td>
				</tr>
				<tr>
					<th>Libelle</th>
					<td>{{ categorie.libelle }}</td>
				</tr>
				<tr>
					<th>Description</th>
					<td>{{ categorie.description }}</td>
				</tr>
				<tr>
					<table class="table">
						<tr>
							<th>id</th>
							<th>libelle</th>
							<th>description</th>
						</tr>
						{% for subForum in categorie.subForums%}
							<tr>
								<td>{{subForum.id}}</td>
								<td>{{ subForum.libelle }}</td>
								<td>{{ subForum.description}}</td>
							</tr>
						{% endfor %}
					</table>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('categorie_index') }}" class="btn btn-secondary">Liste de sieges</a>

		<a href="{{ path('categorie_edition', {'id': categorie.id}) }}" class="btn btn-secondary">Modifier</a>

		{{ include('categorie/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
