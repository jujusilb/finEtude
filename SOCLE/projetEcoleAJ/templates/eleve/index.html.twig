{% extends 'base.html.twig' %}

{% block title %}Hello eleveController!{% endblock %}

{% block body %}
    <a href="{{ path('eleve_nouveau') }}" class="btn" >Creer Nouveau eleve</a>
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>photo</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Username</th>
                <th>E-mail</th>
                <th>password</th>
                <th>Promotion</th>
                <th>role</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for eleve in eleves %}
                <tr>
                    <td>{{eleve.id}}</td>
                    <td>
                        <img src="{{ vich_uploader_asset(eleve, 'imageFile') }}" class="col-md-6 float-md-end mb-3 ms-md-3" style="width: 100px; height: 100px; object-fit: cover;" alt="...">
                    </td>
                    <td>{{ eleve.nom }}</td>
                    <td>{{ eleve.prenom }}</td>
                    <td>{{ eleve.username }}</td>
                    <td>{{ eleve.email }}</td>
                    <td>{{ eleve.password }}</td>
                    <td>
                        <a href="{{ path('promotion_affichage', {'id': eleve.promotion.id}) }}">
                            {{ eleve.promotion.libelle }}
                        </a>
                        
                    </td>
                    <td>
                        {% for role in eleve.roles %}
                            <li>{{ role }}</li>
                        {% endfor %}
                    </td>
                    <td>
                        <a href="{{ path('eleve_affichage', {'id': eleve.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('eleve_edition', {'id': eleve.id}) }}" class="btn btn-secondary">editer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('eleve_nouveau') }}" class="btn" >Creer Nouveau eleve</a>
{% endblock %}
