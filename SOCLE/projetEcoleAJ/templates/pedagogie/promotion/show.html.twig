{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Referent</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ promotion.id }}</td>
				</tr>
				<tr>
					<th>Libelle</th>
					<td>{{ promotion.libelle}}</td>
				</tr>
				<tr>
					<th>referent</th>
					<td>
						<a href="{{ path('professeur_affichage', {'id': promotion.referent.professeur.id}) }}">
							{{ promotion.referent.professeur.prenom}} {{ promotion.referent.professeur.nom}}
						</a>
					</td>
				</tr>
				<tr>
					<th>Eleves</th>
					<td>
						{% for eleve in promotion.eleves %}
							<li>
								<a href="{{ path('eleve_affichage', {'id': eleve.id}) }}">
									{{eleve.prenom}} {{eleve.nom}}
								</a>
							</li>
						{% endfor %}
					</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('promotion_index') }}" class="btn btn-secondary">Liste de sieges</a>

		<a href="{{ path('promotion_edition', {'id': referent.id}) }}" class="btn btn-secondary">Modifier</a>

		{{ include('pedagogie/promotion/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
