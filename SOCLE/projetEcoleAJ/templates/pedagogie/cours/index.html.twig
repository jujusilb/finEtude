{% extends 'base.html.twig' %}

{% block title %}Hello AdminController!{% endblock %}

{% block body %}
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>date</th>
                <th>Libellé</th>
                <th>Professeur</th>
                <th>Promotion</th>
                <th>Matiere</th>
                <th>Professeur</th>
            </tr>
        </thead>
        <tbody>
            {% for cours in courss %}
                <tr>
                    <td>{{cours.id}}</td>
                    <td>{{ cours.date | date('d/m/Y') }}</td>
                    <td>{{cours.libelle}}</td>
                    <td>
                        {% if cours.professeurCours | length > 0 %}
                            {% for cours in cours.professeurCours %}
                                <li>
                                    <a href="{{ path('professeur_affichage', {'id' : cours.professeur.id}) }}">
                                        {{cours.professeur.prenom}} {{ cours.professeur.nom}}
                                    </a>
                                </li>
                            {% endfor %}
                        {% else %}
                            Aucun professeur %}
                        {% endif %}
                    <td>
                        {% for propotion in cours.promotions %}
                        {{ cours.promotion.libelle}}
                        {% endfor %}
                    </td>
                    <td>{{cours.matiere.libelle }}</td>
                    <td>
                        <a href="{{ path('cours_affichage', {'id': cours.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('cours_edition', {'id': cours.id}) }}" class="btn btn-secondary">editer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('cours_nouveau') }}" class="btn" >Creer Nouvel admin</a>
{% endblock %}
