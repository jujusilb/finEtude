<table class="table table-striped table-bordered table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>Expediateur</th>
            <th>Sujet</th>
            <th>Contenu</th>
            <th>Privatif</th>
            <th>Destinataire</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        {% for messageEnvoye in messageEnvoyes %}
            {%if messageEnvoye.privatif > 0 %}    
                <tr>
                    <td>{{messageEnvoye.id}}</td>
                    <td>
                        {% if messageEnvoye.expediteur is not null %}
                            <strong>Expéditeur :</strong> 
                            <a href="{{ path('membre_affichage', {'id': messageEnvoye.expediteur.id}) }}">
                                {{ messageEnvoye.expediteur.prenom }} {{ messageEnvoye.expediteur.nom }}
                            </a>
                        {% else %}
                            <strong>Requerant :</strong> {{ messageEnvoye.requerant }}
                        {% endif %}
                    </td>
                    <td>{{ messageEnvoye.sujet }}</td>
                    <td>{{ messageEnvoye.contenu }}</td>
                    <td>{{ messageEnvoye.privatif }}</td>
                    <td>
                        {% if messageEnvoye.destinataire | length > 0 %}
                            <a href="{{ path('membre_affichage', {'id': messageEnvoye.destinataire.id}) }}">
                                {{ messageEnvoye.destinataire.prenom }} {{ messageEnvoye.destinataire.nom }}</td>
                            </a>
                        {% endif %}
                    </td>                    
                    <td>
                        <a href="{{ path('message_affichage', {'id': messageEnvoye.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('message_edition', {'id': messageEnvoye.id}) }}" class="btn btn-secondary">editer</a>
                    </td>
                </tr>
            {% endif %}
        {% endfor %}
    </tbody>
</table>