{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Repas</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ repas.id }}</td>
				</tr>
				<tr>
					<th>Libelle</th>
					<td>{{ repas.titre }}</td>
				</tr>
				<tr>
					<th>Categorie</th>
					<td>{{ repas.categorie }}</td>
				</tr>
			</tr>
			</tbody>
		</table>

		<a href="{{ path('repas_index') }}" class="btn btn-secondary">Liste de sieges</a>

		<a href="{{ path('repas_edition', {'id': repas.id}) }}" class="btn btn-secondary">Modifier</a>

		{{ include('repas/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
