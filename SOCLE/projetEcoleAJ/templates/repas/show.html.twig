{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Repas</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ repas.id }}</td>
				</tr>
				<tr>
					<th>date d'Achat</th>
					<td>{{ repas.dateAchat | date('d/m/Y') }}</td>
				</tr>
				<tr>
					<th>date</th>
					<td>{{ repas.date | date(' d/m/Y ')  }} {{ repas.heure }}</td>
				</tr>
				<tr>
					<th>Menu</th>
					<td><table class="table">
							<tr>
								<th>Entrée</th>
								<th>Plat</th>
								<th>Fromage</th>
								<th>Desser</th>
							</tr>
							<tr>
								<td>{{ repas.menu.entree.libelle }}</td>
								<td>{{ repas.menu.plat.viande.libelle }} - {{ repas.menu.plat.legume.libelle }}</td>
								<td>{{ repas.menu.fromage.libelle }}</td>
								<td>{{ repas.menu.dessert.libelle }}</td>
							</tr>
						</table>
				</tr>
				<tr>
					<th>Membre</th>
					<td>{{ repas.membre.prenom }} {{ repas.membre.nom }}</td>
				</tr>
								<tr>
					<th>Prix</th>
					<td>{{ repas.prix }}€</td>
				</tr>
			</tr>
			</tbody>
		</table>

		<a href="{{ path('repas_index') }}" class="btn btn-secondary">Liste de sieges</a>

		<a href="{{ path('repas_edition', {'id': repas.id}) }}" class="btn btn-secondary">Modifier</a>

		{{ include('repas/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
