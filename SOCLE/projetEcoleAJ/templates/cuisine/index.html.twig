{% extends 'base.html.twig' %}

{% block title %}Hello cuisineController!{% endblock %}

{% block body %}
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>photo</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>E-mail</th>
                <th>password</th>
                <th>role</th>
                <th>Date d'Embauche</th>
                <th>Poste</th>
                <th>Action</td>
            </tr>
        </thead>
        <tbody>
            {% for cuisine in cuisines %}
                <tr>
                    <td>{{cuisine.id}}</td>
                    <td>
                        <img src="{{ vich_uploader_asset(cuisine, 'imageFile') }}" class="col-md-6 float-md-end mb-3 ms-md-3" style="width: 100px; height: 100px; object-fit: cover;" alt="...">
                    </td>
                    <td>{{ cuisine.nom }}</td>
                    <td>{{ cuisine.prenom }}</td>
                    <td>{{ cuisine.email }}</td>
                    <td>{{ cuisine.password }}</td>
                    <td>
                        {% for role in cuisine.roles %}
                            {{ role }}
                        {% endfor %}
                    </td>
                    <td>{{ cuisine.dateEmbauche | date('d/m/Y') }}</td>
                    <td>{{ cuisine.poste}}</td>
                    <td>
                        <a href="{{ path('cuisine_affichage', {'id': cuisine.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('cuisine_edition', {'id': cuisine.id}) }}" class="btn btn-secondary">editer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('cuisine_nouveau') }}" class="btn" >Creer Nouveau cuisine</a>
{% endblock %}
