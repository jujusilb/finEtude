{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Planning Repas</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ planningRepas.id }}</td>
				</tr>
				<tr>
					<th>Date d\'achat</th>
					<td>{{ planningRepas.dateAchat | date('d/m/Y') }}</td>
				</tr>
				<tr>
					<th>Membre</th>
					<td>{{ planningRepas.membre.prenom }} {{ planningRepas.membre.nom }}</td>
				</tr>
				<tr>
					<th>repas</th>
					<td>
						<table class="table">
							<tr>
								<th>Date - Heure </th>
								<th>Menu</th>
								<th>Prix</th>
							</tr>
							<tr>
								<td>
									{{planningRepas.repas.date |date('d/m/Y')}} - {{planningRepas.repas.heure}}
								</td>
								<td>
									<li>{{planningRepas.repas.menu.entree.libelle}}</li>
									<li>>{{planningRepas.repas.menu.plat.viande.libelle}} - {{planningRepas.repas.menu.plat.legume.libelle}}</li>
									<li>{{planningRepas.repas.menu.fromage.libelle}}</li>
									<li>{{planningRepas.repas.menu.dessert.libelle}}</li>
								</td>
								<td>{{planningRepas.repas.prix}}</td>
							</tr>
						</table>
					</td>				
				</tr>
			</tbody>
		</table>

		<a href="{{ path('planningRepas_index') }}" class="btn btn-secondary">Liste de sieges</a>
		<a href="{{ path('planningRepas_edition', {'id': planningRepas.id}) }}" class="btn btn-secondary">Modifier</a>
		{{ include('cuisine/planning_repas/_delete_form.html.twig') }}
		
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
