{% extends 'base.html.twig' %}

{% block title %}Hello ouvrageController!{% endblock %}

{% block body %}
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Categorie</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for ouvrage in ouvrages %}
                <tr>
                    <td>{{ouvrage.id}}</td>
                    <td>{{ ouvrage.titre }}</td>
                    
                    <td>{% for categorie in ouvrage.categories %}
                    {{categorie }}
                    {% endfor %}</td>
                    <td>{{ ouvrage.statut }}</td>
                    <td>
                        <a href="{{ path('ouvrage_affichage', {'id': ouvrage.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('ouvrage_edition', {'id': ouvrage.id}) }}" class="btn btn-secondary">editer</a>
                    </td>

                </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('ouvrage_nouveau') }}" class="btn" >Creer Nouveau ouvrage</a>
{% endblock %}
