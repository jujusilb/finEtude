{% extends 'base.html.twig' %}

{% block title %}Matiere
{% endblock %}

{% block body %}

	<div class="container">

		<h5>Planning Repas</h5>
		<hr style="width:100%; height:5px; background-color:#1B4F72 ">

		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ planningRepas.id }}</td>
				</tr>
				<tr>
					<th>Date d\'achat</th>
					<td>{{ planningRepas.dateAchat | date('d/m/Y') }}</td>
				</tr>
				<tr>
					<th>Membre</th>
					<td>{{ planningRepas.membre.prenom }} {{ planningRepas.membre.nom }}</td>
				</tr>
				<tr>
					<th>repas</th>
					<td>{{ planningRepas.repas.id }}</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('planningRepas_index') }}" class="btn btn-secondary">Liste de sieges</a>
		<a href="{{ path('planningRepas_edition', {'id': planningRepas.id}) }}" class="btn btn-secondary">Modifier</a>
		{{ include('planning_repas/_delete_form.html.twig') }}
	</div>
	<br>
	<br>
	<br>
	<br>
	<br>
	<br>

{% endblock %}
