{% extends 'base.html.twig' %}

{% block title %}Hello professeurController!{% endblock %}

{% block body %}
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>photo</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Username</th>
                <th>E-mail</th>
                <th>role</th>
                <th>Date d'Embauche</th>
                <th>Poste</th>
                <th class="text-wrap">Matieres</th>
            </tr>
        </thead>
        <tbody>
            {% for professeur in professeurs %}
                <tr>
                    <td>{{professeur.id}}</td>
                    <td>
                        <img src="{{ vich_uploader_asset(professeur, 'imageFile') }}" class="col-md-6 float-md-end mb-3 ms-md-3" width="50px" alt="...">
                    </td>
                    <td>{{ professeur.nom }}</td>
                    <td>{{ professeur.prenom }}</td>
                    <td>{{ professeur.username }}</td>
                    <td>{{ professeur.email }}</td>
                    <td>
                        {% for role in professeur.roles %}
                            <li>{{ role }}</li>
                        {% endfor %}
                    </td>
                    <td>{{ professeur.dateEmbauche | date('d/m/Y') }}</td>
                    <td>{{ professeur.poste}}</td>
                    <td>
                    {% if professeur.ProfesseurMatiere | length > 0 %}
                        <ul>
                            {% for professeurMatiere in professeur.ProfesseurMatiere %}
                               <li>
                                    
                                        {{ professeurMatiere.matiere.libelle }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        Aucune matiere 
                    {% endif %}
                    
                    </td>
                    <td>
                        <a href="{{ path('professeur_affichage', {'id': professeur.id}) }}" class="btn btn-secondary">lire</a>
                        <a href="{{ path('professeur_edition', {'id': professeur.id}) }}" class="btn btn-secondary">editer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>9
    </table>
    <a href="{{ path('professeur_nouveau') }}" class="btn" >Creer Nouveau professeur</a>
{% endblock %}
